# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
build/
dist/
pip-wheel-metadata/

# -----------------------------------------------------------------------------
# Virtual environments (venv/ is ~688 MB locally — never commit)
# -----------------------------------------------------------------------------
venv/
env/
ENV/
.venv/
anaconda_projects/

# -----------------------------------------------------------------------------
# Jupyter / IPython
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints
.jupyter/
profile_default/
ipython_config.py

# -----------------------------------------------------------------------------
# Generated chart output and stray demo artifacts
# static/ holds Plotly HTML files generated at runtime (~147 MB)
# stock_chart.html is a stray 4.4 MB generated chart in the repo root
# -----------------------------------------------------------------------------
static/
stock_chart.html

# -----------------------------------------------------------------------------
# Application runtime artifacts (logs are rotated by app.py)
# -----------------------------------------------------------------------------
logs/
*.log

# -----------------------------------------------------------------------------
# Flask templates (excluded from repo by user request — kept locally only)
# -----------------------------------------------------------------------------
templates/

# -----------------------------------------------------------------------------
# Secrets and credentials — NEVER commit
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.crt
credentials.json
secrets.json
config.local.*

# -----------------------------------------------------------------------------
# IDE / editor / OS
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Test / coverage
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# -----------------------------------------------------------------------------
# Misc local clutter (text.txt is a local scratch file)
# -----------------------------------------------------------------------------
*.bak
*.tmp
*.old
text.txt
